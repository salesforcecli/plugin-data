{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SearchResult",
  "definitions": {
    "SearchResult": {
      "type": "object",
      "properties": {
        "searchRecords": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Record"
          }
        }
      },
      "required": ["searchRecords"],
      "additionalProperties": false
    },
    "Record": {
      "type": "object",
      "properties": {
        "Id": {
          "type": "string"
        },
        "attributes": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": ["type", "url"]
        }
      }
    }
  }
}
